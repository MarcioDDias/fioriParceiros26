<mvc:View controllerName="fiori.z99bp.controller.Parceiros"
    xmlns:mvc="sap.ui.core.mvc" displayBlock="true"
    xmlns="sap.m">
    <Page id="page" title="{i18n>title}">
        <content>

            <List id="listaParceiros"
                  items="{/I_BusinessPartner}">

                <headerToolbar>
                    <OverflowToolbar >
                        <content>
                            <SearchField liveChange="aoPesquisarParceiro" />
                        
                        </content>
                    </OverflowToolbar>
                
                </headerToolbar>

                <items>
                    <StandardListItem title="{BusinessPartnerName}" description="{BusinessPartner}" 
                    />
                </items>
            
            </List>

        </content>
    </Page>
</mvc:View>
